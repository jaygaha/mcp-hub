# Database
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mcp_hub
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis
REDIS_PORT=6379
REDIS_URL="redis://localhost:${REDIS_PORT}"

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend (Next.js, Docker Compose only - see frontend/.env.example for local dev)
FRONTEND_PORT=3000

# Comma-separated list of origins allowed to make credentialed requests
CORS_ORIGINS=http://localhost:3000

# GitHub OAuth (for future auth)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT
JWT_SECRET=change-this-to-a-long-random-value
JWT_ALGORITHM=HS256

# Shared secret required via the X-Admin-Token header on admin-only routes
# (e.g. POST /api/v1/admin/sync-registry). Required outside development.
ADMIN_API_KEY=change-me

# Official Registry
OFFICIAL_REGISTRY_URL=https://registry.modelcontextprotocol.io/v0.1

# Environment: development | production
ENVIRONMENT=development
