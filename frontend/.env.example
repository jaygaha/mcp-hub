# Server-only - never exposed to the browser. Points at the backend the
# frontend's Server Components call directly (no proxy - see README).
# docker compose overrides this to http://backend:8000 for the
# containerized frontend; use this value for local (non-Docker) dev.
BACKEND_INTERNAL_URL=http://localhost:8000

# Public - the only backend URL the browser ever sees, used solely for the
# GitHub login/logout links (which are top-level redirects, not fetches).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
